<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserSuite" parallel="tests" thread-count="3">

    <!-- Each <test> sets the browser parameter; tests run in parallel across browsers -->
    <test name="Signup-Chrome">
        <parameter name="browser" value="chrome" />
        <classes>
            <class name="com.erp.Signup"/>
        </classes>
    </test>

<!--    <test name="Signup-Firefox">
        <parameter name="browser" value="firefox" />
        <classes>
            <class name="com.erp.Signup"/>
        </classes>
    </test>
-->
    <test name="Signup-Edge">
        <parameter name="browser" value="edge" />
        <classes>
            <class name="com.erp.Signup"/>
        </classes>
    </test>

</suite>
